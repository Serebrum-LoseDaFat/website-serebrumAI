# Site URL used in SEO metadata and sitemap
NEXT_PUBLIC_SITE_URL=https://serebrum.ai

# Resend (contact form)
# Get an API key from https://resend.com/api-keys
RESEND_API_KEY=

# Email addresses used by /api/contact
# CONTACT_FROM_EMAIL must be on a domain you've verified in Resend
# (or use "onboarding@resend.dev" for local testing — defaults to this if unset)
CONTACT_FROM_EMAIL=SerebrumAI <contact@serebrum.ai>
CONTACT_TO_EMAIL=hello@serebrum.ai
